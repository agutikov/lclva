# acva compose stack — environment overrides.
#
# Copy to `.env` (alongside `compose.yaml` at the project root) and
# uncomment any variable you want to override. Without a `.env` file the
# defaults baked into docker-compose.yml apply.

# -- Host paths -------------------------------------------------------------
# Where the GGUF / GGML model files live on the host. Mounted read-only at
# /models inside the llama and whisper containers.
# ACVA_MODELS_DIR=/path/to/models

# Where Piper voice ONNX files live on the host. Mounted read-only at /voices
# inside the piper container.
# ACVA_VOICES_DIR=/path/to/voices

# -- Model file selection ---------------------------------------------------
# Switch the LLM model file without editing docker-compose.yml. Path is
# relative to ACVA_MODELS_DIR. Default is bartowski's single-file
# Qwen2.5-7B-Instruct Q4_K_M (4.68 GB). Alternatives are listed in
# scripts/download-llm.sh — pick one with `./scripts/download-llm.sh
# <alias>` and set ACVA_LLM_MODEL to the resulting filename.
# ACVA_LLM_MODEL=Qwen2.5-7B-Instruct-Q4_K_M.gguf

# Switch the Whisper model file. Path is relative to ACVA_MODELS_DIR.
# ACVA_WHISPER_MODEL=ggml-small.bin

# Switch the Piper voice. Path is relative to ACVA_VOICES_DIR.
# ACVA_PIPER_VOICE=en_US-amy-medium.onnx
