# lclva compose stack — environment overrides.
#
# Copy to `.env` (alongside `compose.yaml` at the project root) and
# uncomment any variable you want to override. Without a `.env` file the
# defaults baked into docker-compose.yml apply.

# -- Host paths -------------------------------------------------------------
# Where the GGUF / GGML model files live on the host. Mounted read-only at
# /models inside the llama and whisper containers.
# LCLVA_MODELS_DIR=/path/to/models

# Where Piper voice ONNX files live on the host. Mounted read-only at /voices
# inside the piper container.
# LCLVA_VOICES_DIR=/path/to/voices

# -- Model file selection ---------------------------------------------------
# Switch the LLM model file without editing docker-compose.yml. Path is
# relative to LCLVA_MODELS_DIR. The default is the first shard of the
# split Q4_K_M GGUF — llama.cpp auto-loads the second shard from the
# same directory.
# LCLVA_LLM_MODEL=qwen2.5-7b-instruct-q4_k_m-00001-of-00002.gguf

# Switch the Whisper model file. Path is relative to LCLVA_MODELS_DIR.
# LCLVA_WHISPER_MODEL=ggml-small.bin

# Switch the Piper voice. Path is relative to LCLVA_VOICES_DIR.
# LCLVA_PIPER_VOICE=en_US-amy-medium.onnx
