# acva compose stack — environment overrides.
#
# Copy to `.env` at the project root (alongside `compose.yaml`) and
# edit. Compose-v2 reads `.env` from the working directory of the
# `docker compose` command; the canonical entry point is the root
# (via the `compose.yaml` shim), so `.env` lives there too.
#
# As of M7's `models:` registry rework, every ACVA_* var that affects
# what runs inside Compose is **REQUIRED** by docker-compose.yml — no
# silent defaults. Bring up the stack via:
#
#   cp .env.example .env
#   $EDITOR .env                # set ACVA_MODELS_DIR + LLM
#   docker compose up -d        # from the project root
#
# Or use `tools/acva-models select llm <alias>` — it writes the LLM
# vars into `<repo>/.env` for you.

# -- Host paths -------------------------------------------------------------
# Where model files live on the host. Mounted read-only at /models in
# llama and at the Speaches HF cache path in Speaches.
# Recommended: ${HOME}/.local/share/acva/models (the same XDG path
# tools/acva-models writes to).
ACVA_MODELS_DIR=/home/youruser/.local/share/acva/models

# -- LLM (llama.cpp) --------------------------------------------------------
# GGUF filename (under ACVA_MODELS_DIR/llama.cpp/) loaded at startup.
# Pick one of the aliases registered in `config/default.yaml` under
# `models.llm` and copy the matching `file:` value here. Or run
# `tools/acva-models select llm <alias>` to populate this section
# automatically.
ACVA_LLM_MODEL=qwen3-stage1.q4_k_m.gguf

# Label exposed via llama-server's /v1/models. Should match
# `cfg.llm.model` so request/response logs line up. `tools/acva-models
# select llm` keeps these in sync.
ACVA_LLM_ALIAS=dialog

# -- Speaches (STT + TTS) ---------------------------------------------------
# faster-whisper backend selector. `cuda` requires the NVIDIA Container
# Toolkit; `cpu` is a slow fallback for laptops without GPU.
ACVA_WHISPER_DEVICE=cuda

# faster-whisper compute type. `int8_float16` is the dev-workstation
# default — int8 weights, FP16 activations; ~30% VRAM reduction vs
# float16 with no measurable quality drop on close-mic speech.
# Other options: default | float16 | int8.
ACVA_WHISPER_COMPUTE_TYPE=int8_float16

# Whisper model TTL in seconds. -1 keeps the model loaded forever
# (recommended on the 8 GB RTX 4060 because of faster-whisper #992 —
# the unload path leaks ~300 MB per cycle, so auto-evicting at the
# default 5 min compounds across consecutive runs until inference
# OOMs). 0 disables auto-unload (same effect as -1 for our purposes).
ACVA_WHISPER_TTL=-1
